---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ServicePage from '../components/ServicePage.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import data from '../content/services/direction-strategique-externalisee.json';
---

<BaseLayout title={data.seo.title} description={data.seo.description}>
  <Header />
  <main>
    <ServicePage
      eyebrow={data.eyebrow}
      title={data.title}
      intro={data.intro}
      situationsTitle={data.situationsTitle}
      situations={data.situations}
      servicesTitle={data.servicesTitle}
      services={data.services}
      formatsTitle={data.formatsTitle}
      formats={data.formats}
      resultsTitle={data.resultsTitle}
      results={data.results}
      image={data.image}
    />
    <FinalCta
      title="Besoin d'un regard stratégique régulier ?"
      text="Découvrez comment la direction stratégique externalisée peut renforcer vos décisions sans alourdir votre structure."
      cta={{ label: "Planifier un entretien confidentiel", href: "/contact" }}
    />
  </main>
  <Footer />
</BaseLayout>
