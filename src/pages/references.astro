---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import seo from '../content/references/seo.json';
import hero from '../content/references/hero.json';
import introData from '../content/references/intro.json';
import challengesData from '../content/references/challenges.json';
import testimonialsData from '../content/references/testimonials.json';

type Challenge = { number: string; title: string; context: string; intervention: string; impact: string };

const challenges = (challengesData.items ?? []) as Challenge[];
const hasChallenges = challengesData.active && challenges.length > 0;
const hasTestimonials = testimonialsData.active && testimonialsData.items?.length > 0;
---

<BaseLayout title={seo.title} description={seo.description}>
  <Header />
  <main>

    <!-- ── Hero ── -->
    <section class="ref-hero">
      <img src={hero.heroImage || '/assets/pillet-partners-startup.jpg'} alt="" aria-hidden="true" loading="eager" data-ken-burns />
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="ref-hero-inner">
        <div class="eyebrow">
          <span class="eyebrow-line" data-animate="line" aria-hidden="true"></span>
          <span class="eyebrow-text" data-animate style="--pp-delay:.07s">{hero.eyebrow}</span>
        </div>
        <h1 data-animate style="--pp-delay:.16s">{hero.pageTitle}</h1>
      </div>
    </section>

    <!-- ── Introduction ── -->
    <section class="ref-intro">
      <div class="intro-grid">
        <p class="intro-text" data-reveal>{introData.text}</p>
        <div class="intro-card" data-reveal style="--pp-delay:.12s">
          <ul class="stats-list">
            {introData.stats.map(stat => (
              <li>
                <span class="stat-dash" aria-hidden="true"></span>
                {stat}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ── Défis relevés ── -->
    {hasChallenges && (
      <section class="ref-challenges">
        <div class="challenges-inner">
          <div class="section-eyebrow" data-reveal>
            <span class="section-line-dark" aria-hidden="true"></span>
            <span class="section-label-dark">{challengesData.title}</span>
          </div>
          <p class="challenges-intro" data-reveal style="--pp-delay:.08s">{challengesData.intro}</p>

          <ol class="challenges-list">
            {challenges.map((item, i) => (
              <li class="challenge-item" data-reveal style={`--pp-delay: ${(i * 0.08).toFixed(2)}s`}>
                <span class="challenge-number" aria-hidden="true">{item.number}</span>
                <div class="challenge-body">
                  <h3 class="challenge-title">{item.title}</h3>
                  <div class="challenge-cols">
                    <div class="challenge-col">
                      <span class="col-label">Contexte</span>
                      <p>{item.context}</p>
                    </div>
                    <div class="challenge-col">
                      <span class="col-label">Intervention</span>
                      <p>{item.intervention}</p>
                    </div>
                    <div class="challenge-col col-impact">
                      <span class="col-label">Impact</span>
                      <p>{item.impact}</p>
                    </div>
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}

    <!-- ── Témoignages ── -->
    {hasTestimonials && (
      <section class="ref-testimonials" aria-label="Témoignages">
        <div class="testimonials-inner">
          <div class="section-eyebrow" data-reveal>
            <span class="section-line" aria-hidden="true"></span>
            <span class="section-label">{testimonialsData.title}</span>
          </div>

          <div class="carousel" role="region" aria-label="Carrousel de témoignages">
            <div class="carousel-track">
              {testimonialsData.items.map((t, i) => (
                <div class={`slide${i === 0 ? ' active' : ''}`} role="group" aria-label={`Témoignage ${i + 1} sur ${testimonialsData.items.length}`}>
                  <blockquote class="testimonial-block">
                    <span class="quote-mark" aria-hidden="true">"</span>
                    <p class="quote-text">{t.quote}</p>
                    <footer class="quote-author">
                      <span class="author-line" aria-hidden="true"></span>
                      <cite>{t.author}</cite>
                    </footer>
                  </blockquote>
                </div>
              ))}
            </div>

            {testimonialsData.items.length > 1 && (
              <div class="carousel-controls">
                <button class="carousel-btn prev" aria-label="Témoignage précédent">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                    <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="dots" role="tablist">
                  {testimonialsData.items.map((_, i) => (
                    <button class={`dot${i === 0 ? ' active' : ''}`} role="tab" aria-label={`Aller au témoignage ${i + 1}`} data-index={i}></button>
                  ))}
                </div>
                <button class="carousel-btn next" aria-label="Témoignage suivant">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22">
                    <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <FinalCta
      title="Parlons de votre situation."
      text="Chaque mission est différente, mais toutes poursuivent le même objectif : aider les dirigeants à prendre les bonnes décisions lorsque leur organisation traverse une étape décisive. Un premier échange permet souvent de clarifier rapidement les enjeux et les options possibles."
      cta={{ label: "Planifier un entretien confidentiel", href: "/contact" }}
    />
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  (function () {
    var slides = document.querySelectorAll('.slide');
    if (slides.length < 2) return;
    var dots = document.querySelectorAll('.dot');
    var current = 0;
    var timer = 0;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function goTo(n) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    function startTimer() {
      if (!reduced) timer = setInterval(function () { goTo(current + 1); }, 10000);
    }

    function stopTimer() { clearInterval(timer); }

    startTimer();

    var carousel = document.querySelector('.carousel');
    carousel && carousel.addEventListener('mouseenter', stopTimer);
    carousel && carousel.addEventListener('mouseleave', startTimer);
    carousel && carousel.addEventListener('focusin', stopTimer);
    carousel && carousel.addEventListener('focusout', startTimer);

    var prevBtn = document.querySelector('.prev');
    var nextBtn = document.querySelector('.next');
    prevBtn && prevBtn.addEventListener('click', function () { stopTimer(); goTo(current - 1); startTimer(); });
    nextBtn && nextBtn.addEventListener('click', function () { stopTimer(); goTo(current + 1); startTimer(); });

    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () { stopTimer(); goTo(i); startTimer(); });
    });
  })();
</script>

<style>
/* ── Hero ──────────────────────────────── */

.ref-hero {
  position: relative;
  width: 100%;
  height: 520px;
  overflow: hidden;
  margin-top: 48px;
}

.ref-hero img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 42%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    rgba(14,58,92,.93) 0%,
    rgba(14,58,92,.72) 42%,
    rgba(14,58,92,.18) 74%,
    rgba(14,58,92,0) 100%
  );
}

.ref-hero-inner {
  position: absolute;
  inset: 0;
  padding: 0 var(--pad);
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 840px;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 26px;
}

.eyebrow-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand-2);
  flex-shrink: 0;
}

.eyebrow-text {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand-2);
}

h1 {
  font-family: 'Spectral', serif;
  font-size: clamp(40px, 5.56vw, 80px);
  line-height: 1.04;
  font-weight: 400;
  letter-spacing: -0.018em;
  color: #fff;
  margin: 0;
}

/* ── Introduction ─────────────────────── */

.ref-intro {
  padding: 80px var(--pad) 0;
}

.intro-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 64px;
  align-items: start;
}

.intro-text {
  font-family: 'Spectral', serif;
  font-size: clamp(19px, 1.8vw, 26px);
  line-height: 1.56;
  font-weight: 400;
  font-style: italic;
  color: var(--navy);
  margin: 0;
}

.intro-card {
  border-left: 3px solid var(--sand);
  padding: 28px 32px;
  background: var(--paper);
  border-radius: 0 3px 3px 0;
}

.stats-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.stats-list li {
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 15.5px;
  font-weight: 500;
  color: var(--navy);
  line-height: 1.3;
}

.stat-dash {
  display: block;
  width: 18px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
}

/* ── Section eyebrow pattern ─────────── */

.section-eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 32px;
}

.section-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand-2);
  flex-shrink: 0;
}

.section-label {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand-2);
}

.section-line-dark {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
}

.section-label-dark {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand);
}

/* ── Défis relevés ───────────────────── */

.ref-challenges {
  padding: clamp(72px, 9vw, 112px) var(--pad) 0;
}

.challenges-inner {
  max-width: 1060px;
}

.challenges-intro {
  font-size: clamp(16px, 1.45vw, 18.5px);
  line-height: 1.65;
  color: var(--ink-soft);
  max-width: 720px;
  margin: 0 0 64px;
}

.challenges-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.challenge-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 32px;
  padding: 52px 0;
  border-top: 1px solid rgba(26, 39, 51, 0.13);
}

.challenge-item:last-child {
  border-bottom: 1px solid rgba(26, 39, 51, 0.13);
}

.challenge-number {
  font-family: 'Spectral', serif;
  font-size: 36px;
  color: var(--sand);
  font-weight: 400;
  line-height: 1;
  padding-top: 6px;
}

.challenge-body {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.challenge-title {
  font-family: 'Spectral', serif;
  font-size: clamp(20px, 2vw, 28px);
  font-weight: 400;
  color: var(--navy);
  margin: 0;
  line-height: 1.28;
  letter-spacing: -0.01em;
}

.challenge-cols {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.challenge-col {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.col-label {
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--blue);
}

.col-impact .col-label {
  color: var(--teal, var(--blue));
}

.challenge-col p {
  font-size: 15.5px;
  line-height: 1.6;
  color: var(--ink-soft);
  margin: 0;
}

/* ── Témoignages ─────────────────────── */

.ref-testimonials {
  background: var(--navy);
  margin-top: clamp(72px, 9vw, 112px);
  padding: clamp(64px, 9vw, 112px) var(--pad);
}

.testimonials-inner {
  max-width: 860px;
  margin: 0 auto;
}

.carousel-track {
  display: grid;
  min-height: 260px;
}

.slide {
  grid-area: 1 / 1;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.6s cubic-bezier(.22,1,.36,1), transform 0.6s cubic-bezier(.22,1,.36,1);
  pointer-events: none;
}

.slide.active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

@media (prefers-reduced-motion: reduce) {
  .slide { transition: opacity 0.3s; transform: none; }
}

.testimonial-block {
  margin: 0;
  padding: 0;
}

.quote-mark {
  font-family: 'Spectral', serif;
  font-size: 96px;
  line-height: 0.6;
  color: var(--sand);
  opacity: 0.5;
  display: block;
  margin-bottom: 24px;
  user-select: none;
}

.quote-text {
  font-family: 'Spectral', serif;
  font-size: clamp(18px, 2vw, 26px);
  line-height: 1.56;
  font-style: italic;
  color: rgba(255,255,255,.92);
  margin: 0 0 32px;
}

.quote-author {
  display: flex;
  align-items: center;
  gap: 18px;
}

.author-line {
  display: block;
  width: 32px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
  opacity: 0.7;
}

cite {
  font-style: normal;
  font-size: 14.5px;
  color: rgba(255,255,255,.55);
  letter-spacing: 0.02em;
}

.carousel-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin-top: 48px;
}

.carousel-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 50%;
  background: transparent;
  color: rgba(255,255,255,.6);
  cursor: pointer;
  transition: border-color 0.18s, color 0.18s;
}

.carousel-btn:hover {
  border-color: rgba(255,255,255,.7);
  color: #fff;
}

.dots {
  display: flex;
  gap: 10px;
  align-items: center;
}

.dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: rgba(255,255,255,.25);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background 0.22s, transform 0.22s;
}

.dot.active {
  background: var(--sand);
  transform: scale(1.3);
}

/* ── Responsive ──────────────────────── */

@media (max-width: 960px) {
  .intro-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .intro-card { max-width: 480px; }
  .challenge-cols { grid-template-columns: 1fr 1fr; gap: 24px; }
  .col-impact { grid-column: 1 / -1; }
}

@media (max-width: 768px) {
  .ref-hero { height: 380px; }
  .hero-overlay {
    background: linear-gradient(180deg, rgba(14,58,92,.92) 0%, rgba(14,58,92,.75) 60%, rgba(14,58,92,.22) 100%);
  }
  .ref-intro { padding-top: 64px; }
  .challenge-item { grid-template-columns: 56px 1fr; gap: 20px; padding: 40px 0; }
  .challenge-number { font-size: 28px; }
  .carousel-track { min-height: 300px; }
  .quote-mark { font-size: 72px; }
}

@media (max-width: 560px) {
  .ref-hero { height: 300px; }
  h1 { font-size: clamp(34px, 8vw, 50px); }
  .intro-card { max-width: 100%; }
  .challenge-item { grid-template-columns: 1fr; gap: 12px; padding: 32px 0; }
  .challenge-number { font-size: 22px; padding-top: 0; }
  .challenge-cols { grid-template-columns: 1fr; gap: 20px; }
  .col-impact { grid-column: auto; }
  .carousel-track { min-height: 360px; }
  .quote-text { font-size: 17px; }
}
</style>
