---
import BaseLayout from '../layouts/BaseLayout.astro';
import { marked } from 'marked';
import data from '../content/legal/confidentialite.json';

const htmlContent = marked.parse(data.content || '');
---

<BaseLayout title={data.seo.title} description={data.seo.description}>
  <div class="hero">
    <p class="eyebrow">Pillet &amp; Partners</p>
    <h1>{data.title}</h1>
  </div>

  <div class="container">
    <article class="prose" set:html={htmlContent} />
    <a href="/" class="back">← Retour à l'accueil</a>
  </div>
</BaseLayout>

<style>
.hero {
  background: var(--navy);
  padding: clamp(64px, 10vw, 120px) var(--pad) clamp(48px, 7vw, 80px);
  color: #fff;
}

.eyebrow {
  font-size: 12px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
  margin-bottom: 20px;
}

.hero h1 {
  font-family: 'Spectral', serif;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  color: #fff;
  max-width: 720px;
}

.container {
  max-width: 760px;
  margin: 0 auto;
  padding: clamp(48px, 8vw, 96px) var(--pad);
}

.prose :global(h2) {
  font-family: 'Spectral', serif;
  font-size: clamp(18px, 2vw, 24px);
  font-weight: 500;
  color: var(--navy);
  margin-top: 48px;
  margin-bottom: 16px;
}

.prose :global(h2:first-child) {
  margin-top: 0;
}

.prose :global(p) {
  font-size: 16px;
  line-height: 1.75;
  color: var(--ink-soft);
  margin-bottom: 16px;
}

.prose :global(ul) {
  padding-left: 20px;
  margin-bottom: 16px;
}

.prose :global(li) {
  font-size: 16px;
  line-height: 1.75;
  color: var(--ink-soft);
  margin-bottom: 6px;
}

.prose :global(strong) {
  color: var(--ink);
  font-weight: 600;
}

.prose :global(em) {
  color: rgba(var(--ink-rgb, 20,24,32), .5);
  font-style: italic;
}

.back {
  display: inline-block;
  margin-top: 56px;
  font-size: 14px;
  color: var(--blue);
  transition: color 0.18s;
}

.back:hover {
  color: var(--navy);
}
</style>
