---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SignatureBand from '../components/SignatureBand.astro';
import Challenges from '../components/Challenges.astro';
import Domains from '../components/Domains.astro';
import Approach from '../components/Approach.astro';
import WhyUs from '../components/WhyUs.astro';
import Audience from '../components/Audience.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';

import seo from '../content/home/seo.json';
import hero from '../content/home/hero.json';
import signature from '../content/home/signature.json';
import challenges from '../content/home/challenges.json';
import domains from '../content/home/domains.json';
import approach from '../content/home/approach.json';
import whyUs from '../content/home/why-us.json';
import audience from '../content/home/audience.json';
import finalCta from '../content/home/final-cta.json';
---

<BaseLayout title={seo.title} description={seo.description}>
  <Header />
  <main>
    <Hero {...hero} />
    <SignatureBand {...signature} />
    <Challenges {...challenges} />
    <Domains {...domains} />
    <Approach {...approach} />
    <WhyUs {...whyUs} />
    <Audience {...audience} />
    <FinalCta {...finalCta} />
  </main>
  <Footer />
</BaseLayout>
