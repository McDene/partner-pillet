---
interface Props {
  title: string;
  text: string;
  cta: { label: string; href: string };
}
const { title, text, cta } = Astro.props;
---

<section class="final-cta">
  <h2 data-reveal>{title}</h2>
  <p data-reveal style="--pp-delay:.12s">{text}</p>
  <a href={cta.href} class="cta-btn" data-reveal style="--pp-delay:.22s">{cta.label}</a>
</section>

<style>
.final-cta {
  margin: 110px var(--pad) 96px;
  background: var(--paper);
  border-radius: 4px;
  padding: 72px 80px;
  text-align: center;
}

h2 {
  font-family: 'Spectral', serif;
  font-size: clamp(28px, 3.33vw, 48px);
  font-weight: 400;
  color: var(--navy);
  letter-spacing: -0.015em;
  margin: 0;
}

p {
  margin: 20px auto 0;
  font-size: 19px;
  line-height: 1.6;
  color: var(--ink-soft);
  max-width: 620px;
}

.cta-btn {
  display: inline-flex;
  align-items: center;
  margin-top: 36px;
  background: var(--blue);
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  padding: 18px 34px;
  border-radius: 2px;
  transition: background 0.2s, transform 0.22s cubic-bezier(.22, 1, .36, 1);
}

.cta-btn:hover {
  background: var(--navy);
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .final-cta {
    margin-top: 72px;
    margin-bottom: 64px;
    padding: 52px 36px;
  }
  p { font-size: 17px; }
}

@media (max-width: 480px) {
  .final-cta {
    margin-top: 56px;
    margin-bottom: 48px;
    padding: 40px 24px;
  }
  .cta-btn {
    width: 100%;
    justify-content: center;
    font-size: 15px;
    padding: 15px 20px;
  }
  h2 { font-size: clamp(24px, 6vw, 36px); }
  p { font-size: 16px; }
}
</style>
