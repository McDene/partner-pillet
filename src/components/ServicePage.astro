---
interface Format {
  label: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  situationsTitle: string;
  situations: string[];
  servicesTitle: string;
  services: string[];
  formatsTitle?: string;
  formats?: Format[];
  resultsTitle: string;
  results: string[];
  image?: string;
}

const {
  eyebrow,
  title,
  intro,
  situationsTitle,
  situations,
  servicesTitle,
  services,
  formatsTitle,
  formats,
  resultsTitle,
  results,
  image = '/assets/pillet-partners-startup.jpg',
} = Astro.props;
---

<article class="service-page">

  <!-- ── Hero band ── -->
  <section class="svc-hero">
    <img src={image} alt="" aria-hidden="true" loading="eager" data-ken-burns />
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="hero-line" data-animate="line" aria-hidden="true"></span>
        <span class="hero-label" data-animate style="--pp-delay:.07s">{eyebrow}</span>
      </div>
      <h1 data-animate style="--pp-delay:.16s">{title}</h1>
    </div>
  </section>

  <!-- ── Intro ── -->
  <section class="svc-intro">
    <p data-reveal>{intro}</p>
  </section>

  <!-- ── Situations + Ce que nous apportons ── -->
  <section class="svc-content">
    <div class="content-grid">

      <div class="col">
        <div class="sec-eyebrow">
          <span class="sec-line" data-reveal-line aria-hidden="true"></span>
          <span class="sec-label" data-reveal style="--pp-delay:.06s">{situationsTitle}</span>
        </div>
        <ul class="items-list">
          {situations.map((item, i) => (
            <li data-reveal style={`--pp-delay: ${(i * 0.08).toFixed(2)}s`}>
              <span class="item-num">{i + 1}</span>
              <span class="item-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="col apports-col">
        <div class="sec-eyebrow">
          <span class="sec-line apports-line" data-reveal-line aria-hidden="true"></span>
          <span class="sec-label" data-reveal style="--pp-delay:.06s">{servicesTitle}</span>
        </div>
        <ul class="items-list apports">
          {services.map((item, i) => (
            <li data-reveal style={`--pp-delay: ${(i * 0.08).toFixed(2)}s`}>
              <span class="item-arrow" aria-hidden="true">→</span>
              <span class="item-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>

  <!-- ── Formats (Direction stratégique externalisée uniquement) ── -->
  {formats && formats.length > 0 && (
    <section class="svc-formats">
      <div class="sec-eyebrow">
        <span class="sec-line" data-reveal-line aria-hidden="true"></span>
        <span class="sec-label" data-reveal style="--pp-delay:.06s">{formatsTitle}</span>
      </div>
      <div class="formats-grid">
        {formats.map((f, i) => (
          <div class="format-card" data-reveal style={`--pp-delay: ${(i * 0.14).toFixed(2)}s`}>
            <span class="format-label">{f.label}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ── Résultats ── -->
  <section class="svc-results">
    <div class="results-inner">
      <div class="sec-eyebrow">
        <span class="sec-line" data-reveal-line aria-hidden="true"></span>
        <span class="sec-label" data-reveal style="--pp-delay:.06s">{resultsTitle}</span>
      </div>
      <ul class="results-grid">
        {results.map((item, i) => (
          <li class="result-item" data-reveal style={`--pp-delay: ${(i * 0.1).toFixed(2)}s`}>
            <span class="result-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="result-text">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

</article>

<style>
/* ─── Hero band ─────────────────────────────── */

.svc-hero {
  position: relative;
  width: 100%;
  height: 520px;
  overflow: hidden;
}

.svc-hero img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 42%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    rgba(14,58,92,.93) 0%,
    rgba(14,58,92,.72) 42%,
    rgba(14,58,92,.18) 74%,
    rgba(14,58,92,0) 100%
  );
}

.hero-content {
  position: absolute;
  inset: 0;
  padding: 0 var(--pad);
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 840px;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}

.hero-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand-2);
  flex-shrink: 0;
}

.hero-label {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand-2);
}

h1 {
  font-family: 'Spectral', serif;
  font-size: clamp(36px, 4.44vw, 64px);
  line-height: 1.06;
  font-weight: 400;
  letter-spacing: -0.014em;
  color: #fff;
  margin: 0;
  max-width: 640px;
}

/* ─── Intro ────────────────────────────────── */

.svc-intro {
  padding: 92px var(--pad) 0;
}

.svc-intro p {
  font-family: 'Spectral', serif;
  font-size: clamp(19px, 1.87vw, 27px);
  line-height: 1.58;
  font-weight: 400;
  font-style: italic;
  color: var(--navy);
  max-width: 880px;
  margin: 0;
}

/* ─── Eyebrow pattern (sections) ───────────── */

.sec-eyebrow {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 26px;
}

.sec-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
}

.apports-line {
  background: var(--blue);
}

.sec-label {
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--sand);
}

/* ─── Content grid (situations + services) ─── */

.svc-content {
  padding: 84px var(--pad) 0;
}

.content-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}

.items-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.items-list li {
  display: flex;
  gap: 20px;
  align-items: baseline;
  padding: 16px 0;
  border-top: 1px solid rgba(26, 39, 51, 0.13);
}

.item-num {
  font-family: 'Spectral', serif;
  font-size: 15px;
  color: var(--sand);
  font-style: italic;
  flex: 0 0 auto;
  width: 20px;
}

.item-arrow {
  font-size: 16px;
  color: var(--blue);
  flex: 0 0 auto;
  width: 20px;
  transition: transform 0.25s cubic-bezier(.22, 1, .36, 1);
}

.apports li:hover .item-arrow {
  transform: translateX(5px);
}

.item-text {
  font-size: 18px;
  line-height: 1.42;
  color: var(--ink);
}

/* ─── Formats (DSE uniquement) ─────────────── */

.svc-formats {
  padding: 84px var(--pad) 0;
}

.formats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.format-card {
  position: relative;
  padding-top: 28px;
}

.format-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  height: 2px;
  width: 100%;
  background: var(--navy);
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.5s cubic-bezier(.22, 1, .36, 1);
  transition-delay: calc(var(--pp-delay, 0s) + 0.24s);
}

.format-card.revealed::before {
  transform: scaleX(1);
}

.format-label {
  font-family: 'Spectral', serif;
  font-size: clamp(22px, 2.22vw, 32px);
  font-weight: 400;
  color: var(--navy);
  letter-spacing: -0.01em;
  line-height: 1.2;
}

/* ─── Résultats ─────────────────────────────── */

.svc-results {
  margin-top: 84px;
}

.results-inner {
  background: var(--paper);
  margin: 0 var(--pad);
  border-radius: 4px;
  padding: 72px 80px;
}

.results-grid {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.result-item {
  position: relative;
  padding: 32px 48px 32px 0;
  border-top: 1px solid rgba(26, 39, 51, 0.13);
}

.result-item::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 0;
  height: 2px;
  width: 0%;
  background: var(--teal);
  transition: width 0.55s cubic-bezier(.22, 1, .36, 1);
  transition-delay: calc(var(--pp-delay, 0s) + 0.2s);
}

.result-item.revealed::before {
  width: 100%;
}

.result-num {
  display: block;
  font-family: 'Spectral', serif;
  font-size: 15px;
  font-style: italic;
  color: var(--sand);
  margin-bottom: 12px;
}

.result-text {
  display: block;
  font-family: 'Spectral', serif;
  font-size: clamp(20px, 1.87vw, 27px);
  font-weight: 400;
  color: var(--navy);
  line-height: 1.2;
  letter-spacing: -0.01em;
}

/* ─── Responsive ────────────────────────────── */

@media (max-width: 900px) {
  .content-grid { grid-template-columns: 1fr; gap: 56px; }
  .formats-grid { grid-template-columns: 1fr; gap: 0; }
  .format-card { border-top: 1px solid rgba(26,39,51,.13); padding: 24px 0; }
  .format-card::before { display: none; }
  .results-grid { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .svc-hero { height: 380px; }
  .hero-overlay {
    background: linear-gradient(180deg, rgba(14,58,92,.92) 0%, rgba(14,58,92,.75) 60%, rgba(14,58,92,.22) 100%);
  }
  .svc-intro p { font-size: 18px; }
  .results-inner { margin: 0; border-radius: 0; padding: 56px var(--pad); }
  .item-text { font-size: 17px; }
}

@media (max-width: 480px) {
  .svc-hero { height: 300px; }
  h1 { font-size: clamp(28px, 7vw, 40px); }
  .svc-intro { padding-top: 64px; }
  .svc-intro p { font-size: 17px; }
  .svc-content, .svc-formats { padding-top: 60px; }
  .svc-results { margin-top: 60px; }
  .results-inner { padding: 40px 24px; }
  .result-item { padding: 24px 0 24px 0; }
  .result-text { font-size: 19px; }
}
</style>
