---
interface Props {
  eyebrow: string;
  quote: string;
  quoteAccent: string;
  quoteEnd: string;
  image: string;
}
const { eyebrow, quote, quoteAccent, quoteEnd, image } = Astro.props;
---

<section class="signature-band">
  <img src={image} alt="Coupe d'un tronc — les cernes de croissance" loading="lazy" data-ken-burns />
  <div class="overlay" aria-hidden="true"></div>
  <div class="content" data-reveal>
    <div class="eyebrow">
      <span class="eyebrow-line" data-reveal-line style="--pp-delay:.1s" aria-hidden="true"></span>
      <span class="eyebrow-text">{eyebrow}</span>
    </div>
    <p class="quote">
      {quote} <em>{quoteAccent}</em>{quoteEnd}
    </p>
  </div>
</section>

<style>
.signature-band {
  position: relative;
  width: 100%;
  height: 468px;
  overflow: hidden;
  margin-top: 96px;
}

img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 60%;
}

.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(14,58,92,.88) 0%, rgba(14,58,92,.62) 40%, rgba(14,58,92,.12) 72%, rgba(14,58,92,0) 100%);
}

.content {
  position: absolute;
  inset: 0;
  padding: 0 var(--pad);
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 820px;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 26px;
}

.eyebrow-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand-2);
  flex-shrink: 0;
}

.eyebrow-text {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand-2);
}

.quote {
  font-family: 'Spectral', serif;
  font-size: clamp(24px, 2.78vw, 40px);
  line-height: 1.28;
  font-weight: 400;
  color: #fff;
  max-width: 660px;
}

.quote em {
  font-style: italic;
  color: var(--sand-2);
}

@media (max-width: 768px) {
  .signature-band { height: 320px; }
  .overlay {
    background: linear-gradient(180deg, rgba(14,58,92,.88) 0%, rgba(14,58,92,.72) 60%, rgba(14,58,92,.2) 100%);
  }
}
</style>
