---
interface Reason {
  title: string;
  description: string;
}
interface Props {
  eyebrow: string;
  title: string;
  portrait: string;
  portraitName: string;
  portraitRole: string;
  reasons: Reason[];
}
const { eyebrow, title, portrait, portraitName, portraitRole, reasons } = Astro.props;
---

<section class="why-us" id="pourquoi">
  <div class="grid">
    <div class="col-left">
      <div class="eyebrow">
        <span class="eyebrow-line" data-reveal-line aria-hidden="true"></span>
        <span class="eyebrow-text" data-reveal style="--pp-delay:.07s">{eyebrow}</span>
      </div>
      <h2 data-reveal style="--pp-delay:.14s">{title}</h2>
      <figure data-reveal style="--pp-delay:.22s">
        <div class="portrait-frame">
          <img src={portrait} alt={`${portraitName}, ${portraitRole}`} loading="lazy" />
        </div>
        <figcaption>
          <span class="caption-line" aria-hidden="true"></span>
          <span><em>{portraitName}</em> — {portraitRole}</span>
        </figcaption>
      </figure>
    </div>
    <div class="reasons">
      {reasons.map((reason, i) => (
        <div class="reason" data-reveal style={`--pp-delay: ${(i * 0.1).toFixed(2)}s`}>
          <h3>{reason.title}</h3>
          <p>{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.why-us {
  padding: 100px var(--pad) 0;
}

.grid {
  display: grid;
  grid-template-columns: 0.8fr 1.2fr;
  gap: 80px;
  align-items: start;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}

.eyebrow-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
}

.eyebrow-text {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand);
}

h2 {
  font-family: 'Spectral', serif;
  font-size: clamp(28px, 2.92vw, 42px);
  line-height: 1.12;
  font-weight: 400;
  color: var(--navy);
  letter-spacing: -0.01em;
  margin: 0;
}

figure {
  margin-top: 40px;
  margin-bottom: 0;
}

.portrait-frame {
  overflow: hidden;
  border-radius: 3px;
  height: 440px;
}

.portrait-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 18%;
  transition: transform 0.65s cubic-bezier(.25, .46, .45, .94);
}

.portrait-frame:hover img {
  transform: scale(1.04) translateY(-1%);
}

figcaption {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-top: 18px;
}

.caption-line {
  display: block;
  width: 26px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
}

figcaption span:last-child {
  font-size: 16px;
  color: var(--ink);
}

figcaption em {
  font-family: 'Spectral', serif;
  font-style: italic;
}

.reasons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 44px 56px;
}

.reason h3 {
  font-family: 'Spectral', serif;
  font-size: 22px;
  font-weight: 500;
  color: var(--ink);
  line-height: 1.25;
  margin: 0;
}

.reason p {
  margin: 12px 0 0;
  font-size: 16.5px;
  line-height: 1.55;
  color: var(--ink-soft);
}

@media (max-width: 900px) {
  .grid {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .portrait-frame { height: 300px; }
}

@media (max-width: 768px) {
  .why-us { padding-top: 64px; }
  .portrait-frame { height: 260px; }
}

@media (max-width: 600px) {
  .reasons { grid-template-columns: 1fr; gap: 32px; }
}

@media (max-width: 400px) {
  .why-us { padding-top: 44px; }
  .portrait-frame { height: 220px; }
}
</style>
