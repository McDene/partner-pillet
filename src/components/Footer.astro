---
import footerSettings from '../content/settings/footer.json';
import mentionsLegales from '../content/legal/mentions-legales.json';

const year = new Date().getFullYear();
const linkedinUrl = footerSettings.linkedin?.trim() || '';
const showMentions = mentionsLegales.actif === true;
---

<footer>
  <div class="top-row">
    <div class="brand">
      <div class="brand-mark" aria-hidden="true"></div>
      <span class="brand-name">PILLET&nbsp;&amp;&nbsp;PARTNERS</span>
    </div>
    {linkedinUrl && (
      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="linkedin" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    )}
  </div>

  <p class="tagline">Conseil stratégique · Suisse romande</p>

  <div class="bottom-row">
    <div class="links">
      {showMentions && <a href="/mentions-legales">Mentions légales</a>}
      <a href="/confidentialite">Confidentialité</a>
    </div>
    <p class="copy">&copy; {year} Pillet &amp; Partners</p>
  </div>
</footer>

<style>
footer {
  background: var(--navy);
  padding: 56px var(--pad);
  color: #fff;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14px;
}

.brand-mark {
  width: 36px;
  height: 36px;
  background-image: url('/assets/logo.png');
  background-size: 60px 60px;
  background-repeat: no-repeat;
  background-position: top center;
  flex-shrink: 0;
  filter: brightness(0) invert(1);
}

.brand-name {
  font-family: 'Spectral', serif;
  font-size: 18px;
  font-weight: 500;
  letter-spacing: 0.14em;
  color: #fff;
}

.linkedin {
  display: flex;
  align-items: center;
  color: rgba(255,255,255,.6);
  transition: color 0.18s;
}

.linkedin:hover {
  color: #fff;
}

.tagline {
  font-size: 14px;
  color: rgba(255,255,255,.5);
  margin-bottom: 32px;
}

.bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.links {
  display: flex;
  gap: 28px;
}

.links a {
  font-size: 13px;
  color: rgba(255,255,255,.5);
  transition: color 0.18s;
}

.links a:hover {
  color: #fff;
}

.copy {
  font-size: 13px;
  color: rgba(255,255,255,.4);
}

@media (max-width: 768px) {
  footer { padding-top: 44px; padding-bottom: 44px; }
  .tagline { margin-bottom: 24px; }
}

@media (max-width: 480px) {
  footer { padding-top: 36px; padding-bottom: 36px; }
  .bottom-row { flex-direction: column; align-items: flex-start; gap: 12px; }
}
</style>
