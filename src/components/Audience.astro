---
interface Props {
  eyebrow: string;
  items: string[];
}
const { eyebrow, items } = Astro.props;
---

<section class="audience">
  <div class="eyebrow">
    <span class="eyebrow-line" data-reveal-line aria-hidden="true"></span>
    <span class="eyebrow-text" data-reveal style="--pp-delay:.07s">{eyebrow}</span>
  </div>
  <div class="pills">
    {items.map((item, i) => (
      <span class="pill" data-reveal style={`--pp-delay: ${(i * 0.06).toFixed(2)}s`}>{item}</span>
    ))}
  </div>
</section>

<style>
.audience {
  padding: 100px var(--pad) 0;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}

.eyebrow-line {
  display: block;
  width: 38px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
}

.eyebrow-text {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sand);
}

.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  max-width: 1040px;
}

.pill {
  font-family: 'Spectral', serif;
  font-size: clamp(16px, 1.53vw, 22px);
  color: var(--navy);
  padding: 12px 26px;
  border: 1px solid rgba(26, 39, 51, 0.2);
  border-radius: 999px;
  transition: border-color 0.22s, background 0.22s, color 0.22s;
  cursor: default;
}

.pill:hover {
  border-color: var(--navy);
  background: rgba(14, 58, 92, 0.04);
}

@media (max-width: 768px) {
  .audience { padding-top: 64px; }
  .pill { font-size: 16px; padding: 10px 20px; }
}

@media (max-width: 400px) {
  .audience { padding-top: 44px; }
}
</style>
