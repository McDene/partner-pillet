---
interface DomainItem {
  number: string;
  title: string;
  description: string;
  href?: string;
  situations?: string[];
}
interface Props {
  title: string;
  eyebrow: string;
  items: DomainItem[];
}
const { title, eyebrow, items } = Astro.props;
---

<section class="domains" id="domaines">
  <div class="header">
    <h2 data-reveal>{title}</h2>
    <span class="eyebrow-right" data-reveal style="--pp-delay:.1s">{eyebrow}</span>
  </div>
  <ul>
    {items.map((item, i) => (
      <li class={i === items.length - 1 ? 'last' : ''} data-reveal style={`--pp-delay: ${(i * 0.07).toFixed(2)}s`}>
        {item.href && item.href !== '#' ? (
          <a href={item.href} class="row-link">
            <span class="number">{item.number}</span>
            <div class="content">
              <h3>{item.title}</h3>
              <div class="content-right">
                <p>{item.description}</p>
                {item.situations && item.situations.length > 0 && (
                  <ul class="situations">
                    {item.situations.map(s => <li>{s}</li>)}
                  </ul>
                )}
              </div>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="row-link">
            <span class="number">{item.number}</span>
            <div class="content">
              <h3>{item.title}</h3>
              <div class="content-right">
                <p>{item.description}</p>
                {item.situations && item.situations.length > 0 && (
                  <ul class="situations">
                    {item.situations.map(s => <li>{s}</li>)}
                  </ul>
                )}
              </div>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </span>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
.domains {
  padding: 96px var(--pad) 0;
}

.header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 30px;
  gap: 20px;
}

h2 {
  font-family: 'Spectral', serif;
  font-size: clamp(26px, 2.64vw, 38px);
  font-weight: 400;
  color: var(--navy);
  letter-spacing: -0.01em;
  margin: 0;
}

.eyebrow-right {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--sand);
  white-space: nowrap;
}

ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

li {
  border-top: 1px solid rgba(26, 39, 51, 0.13);
  border-radius: 2px;
}

li.last {
  border-bottom: 1px solid rgba(26, 39, 51, 0.13);
}

.row-link {
  display: grid;
  grid-template-columns: 92px 1fr 26px;
  align-items: center;
  gap: 30px;
  padding: 30px 4px;
  text-decoration: none;
  transition: background 0.22s;
  border-radius: 2px;
}

a.row-link:hover {
  background: rgba(14, 58, 92, 0.028);
}

.number {
  font-family: 'Spectral', serif;
  font-size: 30px;
  color: var(--sand);
  font-weight: 400;
}

.content {
  display: flex;
  align-items: baseline;
  gap: 28px;
}

.content-right {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-width: 520px;
}

h3 {
  font-family: 'Spectral', serif;
  font-size: 27px;
  font-weight: 400;
  color: var(--ink);
  margin: 0;
  flex: 0 0 360px;
  transition: color 0.2s;
}

a.row-link:hover h3 {
  color: var(--blue);
}

p {
  margin: 0;
  font-size: 16.5px;
  line-height: 1.5;
  color: var(--ink-soft);
}

.situations {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  list-style: none;
  padding: 0;
  margin: 0;
}

.situations li {
  border: none;
  font-size: 13px;
  font-style: italic;
  color: var(--ink-soft);
  opacity: 0.72;
  background: rgba(26, 39, 51, 0.055);
  border-radius: 999px;
  padding: 4px 13px;
  line-height: 1.4;
  white-space: nowrap;
}

.arrow {
  font-size: 20px;
  color: var(--blue);
  transition: transform 0.28s cubic-bezier(.22, 1, .36, 1);
}

a.row-link:hover .arrow {
  transform: translateX(6px);
}

@media (max-width: 900px) {
  .row-link {
    grid-template-columns: 60px 1fr 20px;
    gap: 16px;
  }
  h3 {
    flex: none;
    font-size: 22px;
  }
  .content {
    flex-direction: column;
    gap: 8px;
  }
  .content-right { max-width: 100%; }
}

@media (max-width: 768px) {
  .domains { padding-top: 64px; }
  .header { flex-direction: column; gap: 6px; align-items: flex-start; }
}

@media (max-width: 600px) {
  .row-link {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .number { font-size: 20px; }
  .arrow { display: none; }
  .situations li { white-space: normal; }
}

@media (max-width: 480px) {
  .row-link { padding: 20px 0; gap: 8px; }
  .number { font-size: 18px; }
}

@media (max-width: 400px) {
  .domains { padding-top: 44px; }
  h3 { font-size: 19px; }
  p { font-size: 15px; }
}
</style>
