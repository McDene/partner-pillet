---
interface DomainItem {
  number: string;
  title: string;
  description: string;
  href?: string;
}
interface Props {
  title: string;
  eyebrow: string;
  items: DomainItem[];
  situationsTitle?: string;
  situations?: string[];
}
const { title, eyebrow, items, situationsTitle, situations } = Astro.props;
const hasSituations = situations && situations.length > 0;
---

<section class="domains" id="domaines">
  <div class="header">
    <h2 data-reveal>{title}</h2>
    <span class="eyebrow-right" data-reveal style="--pp-delay:.1s">{eyebrow}</span>
  </div>
  <ul>
    {items.map((item, i) => (
      <li class={i === items.length - 1 ? 'last' : ''} data-reveal style={`--pp-delay: ${(i * 0.07).toFixed(2)}s`}>
        {item.href && item.href !== '#' ? (
          <a href={item.href} class="row-link">
            <span class="number">{item.number}</span>
            <div class="content">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="row-link">
            <span class="number">{item.number}</span>
            <div class="content">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </span>
        )}
      </li>
    ))}
  </ul>

  {hasSituations && (
    <div class="situations-block" data-reveal>
      <span class="situations-label">{situationsTitle || 'Exemples de situations concrètes'}</span>
      <ul class="situations-list">
        {situations!.map(s => (
          <li>
            <span class="situation-dash" aria-hidden="true"></span>
            {s}
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<style>
.domains {
  padding: 96px var(--pad) 0;
}

.header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 30px;
  gap: 20px;
}

h2 {
  font-family: 'Spectral', serif;
  font-size: clamp(26px, 2.64vw, 38px);
  font-weight: 400;
  color: var(--navy);
  letter-spacing: -0.01em;
  margin: 0;
}

.eyebrow-right {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--sand);
  white-space: nowrap;
}

ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

li {
  border-top: 1px solid rgba(26, 39, 51, 0.13);
  border-radius: 2px;
}

li.last {
  border-bottom: 1px solid rgba(26, 39, 51, 0.13);
}

.row-link {
  display: grid;
  grid-template-columns: 92px 1fr 26px;
  align-items: center;
  gap: 30px;
  padding: 30px 4px;
  text-decoration: none;
  transition: background 0.22s;
  border-radius: 2px;
}

a.row-link:hover {
  background: rgba(14, 58, 92, 0.028);
}

.number {
  font-family: 'Spectral', serif;
  font-size: 30px;
  color: var(--sand);
  font-weight: 400;
}

.content {
  display: flex;
  align-items: baseline;
  gap: 28px;
}

h3 {
  font-family: 'Spectral', serif;
  font-size: 27px;
  font-weight: 400;
  color: var(--ink);
  margin: 0;
  flex: 0 0 360px;
  transition: color 0.2s;
}

a.row-link:hover h3 {
  color: var(--blue);
}

p {
  margin: 0;
  font-size: 16.5px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 520px;
}

.arrow {
  font-size: 20px;
  color: var(--blue);
  transition: transform 0.28s cubic-bezier(.22, 1, .36, 1);
}

a.row-link:hover .arrow {
  transform: translateX(6px);
}

/* ── Situations block ── */

.situations-block {
  margin-top: 40px;
  padding: 32px 40px;
  background: var(--paper);
  border-left: 3px solid var(--sand);
  border-radius: 0 3px 3px 0;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.situations-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--sand);
}

.situations-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.situations-list li {
  border: none;
  display: flex;
  align-items: baseline;
  gap: 14px;
  font-family: 'Spectral', serif;
  font-size: clamp(16px, 1.5vw, 19px);
  font-style: italic;
  line-height: 1.5;
  color: var(--navy);
}

.situation-dash {
  display: block;
  width: 18px;
  height: 1px;
  background: var(--sand);
  flex-shrink: 0;
  margin-top: 0.6em;
}

/* ── Responsive ── */

@media (max-width: 900px) {
  .row-link {
    grid-template-columns: 60px 1fr 20px;
    gap: 16px;
  }
  h3 {
    flex: none;
    font-size: 22px;
  }
  .content {
    flex-direction: column;
    gap: 8px;
  }
}

@media (max-width: 768px) {
  .domains { padding-top: 64px; }
  .header { flex-direction: column; gap: 6px; align-items: flex-start; }
  .situations-block { padding: 24px 28px; }
}

@media (max-width: 600px) {
  .row-link {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .number { font-size: 20px; }
  .arrow { display: none; }
}

@media (max-width: 480px) {
  .row-link { padding: 20px 0; gap: 8px; }
  .number { font-size: 18px; }
  .situations-block { padding: 20px 20px; }
}

@media (max-width: 400px) {
  .domains { padding-top: 44px; }
  h3 { font-size: 19px; }
  p { font-size: 15px; }
}
</style>
