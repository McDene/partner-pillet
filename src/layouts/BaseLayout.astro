---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/400-italic.css';
import '@fontsource/spectral/500.css';
import '@fontsource/spectral/600.css';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = "Pillet & Partners — Conseil stratégique en Suisse romande", noindex = false } = Astro.props;

const siteUrl = "https://radiant-bavarois-2c95dd.netlify.app";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = `${siteUrl}/og-image.png`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Pillet & Partners",
  "description": "Cabinet de conseil stratégique en Suisse romande accompagnant les dirigeants de PME dans leurs étapes décisives.",
  "url": siteUrl,
  "logo": `${siteUrl}/assets/logo.png`,
  "image": ogImage,
  "founder": {
    "@type": "Person",
    "name": "Line Pillet",
    "jobTitle": "Fondatrice & Managing Partner"
  },
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Suisse romande"
  },
  "knowsAbout": [
    "Conseil stratégique",
    "Transitions stratégiques",
    "Transformation organisationnelle",
    "Transmission et gouvernance d'entreprise",
    "Direction stratégique externalisée"
  ],
  "inLanguage": "fr-CH"
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <!-- Open Graph (LinkedIn, Facebook, WhatsApp…) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_CH" />
    <meta property="og:site_name" content="Pillet & Partners" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Robots -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <slot />
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
